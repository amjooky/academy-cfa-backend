PORT=3000
NODE_ENV=development
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
REDIS_URL=redis://127.0.0.1:6379

# XAMPP MySQL — set MYSQL_PASSWORD if your root user has a password
DB_URL=mysql://root@127.0.0.1:3306/
